# =============================================================================
# Policy Mesh — environment configuration example
# Copy to .env and adjust. For Docker Compose, the app service overrides
# DATABASE_URL to use host "postgres"; use localhost for migrations from host.
# =============================================================================

# -----------------------------------------------------------------------------
# Policy file (required)
# -----------------------------------------------------------------------------
# Path to JSON policy file (sensitivity keywords, cost thresholds, default provider).
# Required: if unset or file missing/invalid, the application errors. See docs/POLICY_FILE_SCHEMA.md and docs/policies.example.json.
POLICY_FILE=./policies.json

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# Used by: docker-compose postgres service; app for audit persistence.
POSTGRES_USER=policy_mesh
POSTGRES_PASSWORD=change-me
POSTGRES_DB=policy_mesh
POSTGRES_PORT=5432

# Connection string for the app and for running migrations from the host.
# In Docker, the app container gets DATABASE_URL overridden to use host "postgres".
DATABASE_URL=postgresql+psycopg://policy_mesh:change-me@localhost:5432/policy_mesh

# Set to false to disable audit writes even when DATABASE_URL is set.
# AUDIT_ENABLED=true

# Routing policy (sensitivity, cost, default provider) is loaded from POLICY_FILE only.
# See docs/POLICY_FILE_SCHEMA.md and docs/policies.example.json.

# -----------------------------------------------------------------------------
# Providers (local LLM & public/cloud LLM)
# -----------------------------------------------------------------------------
# Local LLM base URL (e.g. Ollama). Default http://localhost:11434. In Docker use http://ollama:11434.
LOCAL_LLM_URL=http://localhost:11434

# Optional API key for local LLM (e.g. Ollama with auth). Leave unset if not required.
# LOCAL_LLM_API_KEY=

# Public/cloud LLM: required when routing to OpenAI or other cloud provider. Provider inferred from URL.
# PUBLIC_LLM_API_KEY=sk-...

# Public LLM base URL. Default https://api.openai.com when unset.
# PUBLIC_LLM_URL=https://api.openai.com

# HTTP timeout in seconds for provider requests. Default: 60.
# PROVIDER_TIMEOUT_SECONDS=60
